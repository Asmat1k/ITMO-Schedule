{
  "manifest_version": 3,
  "name": "ISP",
  "version": "0.1.0",
  "description": "Itmo Schedule Parser (ISP) — экспорт расписания ИТМО в файл .ics для импорта в Google Calendar.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://my.itmo.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
